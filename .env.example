# ================================================================
# 환경변수 템플릿 — 실제 값은 절대 이 파일에 적지 마십시오.
# 이 파일을 복사해서 .env 를 만들고 값을 채우세요.
# .env 파일은 .gitignore 에 등록되어 있어 GitHub에 올라가지 않습니다.
# ================================================================

# ── Frontend ──────────────────────────────────────────────────
# GitHub Pages 배포 시: VITE_BASE_PATH=/woneydepp.github.io/
# Docker 로컬 실행 시: 이 줄을 비워두세요 (자동으로 '/' 사용)
VITE_BASE_PATH=

# ── Java API (로컬 Docker 환경) ────────────────────────────────
SPRING_DATASOURCE_URL=jdbc:postgresql://postgres:5432/portfolio
SPRING_DATASOURCE_USERNAME=your_db_username
SPRING_DATASOURCE_PASSWORD=your_db_password
SPRING_REDIS_HOST=redis
SPRING_REDIS_PORT=6379

# ── Java API (AWS 환경으로 전환 시 아래로 교체) ──────────────────
# SPRING_DATASOURCE_URL=jdbc:postgresql://{RDS_ENDPOINT}:5432/portfolio
# SPRING_DATASOURCE_USERNAME=your_rds_username
# SPRING_DATASOURCE_PASSWORD=your_rds_password
# SPRING_REDIS_HOST={ELASTICACHE_ENDPOINT}
# SPRING_REDIS_PORT=6379

# ── PostgreSQL (로컬 Docker 컨테이너용) ──────────────────────────
POSTGRES_DB=portfolio
POSTGRES_USER=your_db_username
POSTGRES_PASSWORD=your_db_password

# ── Python Data Service ────────────────────────────────────────
GITHUB_TOKEN=your_github_personal_access_token
REDIS_HOST=redis
REDIS_PORT=6379
